<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.quant.stock.mapper.BacktestRecordMapper">

    <resultMap id="RecMap" type="com.quant.stock.backtest.dto.BtBacktestRecordDO">
        <id column="id" property="id"/>
        <result column="record_id" property="recordId"/>
        <result column="kind" property="kind"/>
        <result column="saved_at" property="savedAt"/>
        <result column="stock_code" property="stockCode"/>
        <result column="stock_codes_json" property="stockCodesJson"/>
        <result column="period" property="period"/>
        <result column="back_start" property="backStart"/>
        <result column="back_end" property="backEnd"/>
        <result column="init_capital" property="initCapital"/>
        <result column="final_asset" property="finalAsset"/>
        <result column="total_rate" property="totalRate"/>
        <result column="max_drawdown" property="maxDrawdown"/>
        <result column="total_trade_num" property="totalTradeNum"/>
        <result column="win_rate" property="winRate"/>
        <result column="trade_stats_json" property="tradeStatsJson"/>
        <result column="trades_json" property="tradesJson"/>
        <result column="stock_results_json" property="stockResultsJson"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO bt_backtest_record
        (record_id, kind, saved_at, stock_code, stock_codes_json, period, back_start, back_end,
         init_capital, final_asset, total_rate, max_drawdown, total_trade_num, win_rate,
         trade_stats_json, trades_json, stock_results_json)
        VALUES
        (#{recordId}, #{kind}, #{savedAt}, #{stockCode}, #{stockCodesJson}, #{period},
         #{backStart}, #{backEnd}, #{initCapital}, #{finalAsset}, #{totalRate}, #{maxDrawdown},
         #{totalTradeNum}, #{winRate}, #{tradeStatsJson}, #{tradesJson}, #{stockResultsJson})
    </insert>

    <select id="selectByKind" resultMap="RecMap">
        SELECT * FROM bt_backtest_record
        WHERE kind = #{kind}
        <if test="stockCode != null and stockCode != ''">
            AND stock_code = #{stockCode}
        </if>
        ORDER BY saved_at DESC, id DESC
    </select>

    <delete id="deleteSingleByCode">
        DELETE FROM bt_backtest_record WHERE kind = 'SINGLE' AND stock_code = #{stockCode}
    </delete>

    <delete id="deleteAllByKind">
        DELETE FROM bt_backtest_record WHERE kind = #{kind}
    </delete>
</mapper>
